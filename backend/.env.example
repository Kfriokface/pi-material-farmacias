NODE_ENV=dev
PORT=3000

# Cadena de conexión MySQL
DATABASE_URL="mysql://usuario:password@localhost:3306/farmacia_db"

# Ruta local donde se almacenan los archivos subidos
FILES_PATH=/ruta/al/backend/files

# URL pública desde la que se sirven los archivos (puede ser la misma que APP_URL + /files)
FILES_URL=http://localhost:3000/files

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRATION=24h

# SMTP (para envío de emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM=Material Farmacias <tu_email@gmail.com>

# URL pública de la app (usada en enlaces de emails)
APP_URL=http://localhost:3000
