# Copia este archivo como .env y ajusta los valores
# Variables comunes a todos los entornos
VITE_APP_NAME=Material Farmacias
VITE_APP_VERSION=1.0.0

# URL base de la API (sin .env, usa http://localhost:3000/api por defecto)
VITE_API_URL=https://tu-dominio.com/api

# URL base para archivos estáticos servidos por el backend
VITE_FILES_URL=https://tu-dominio.com/files

# API Key de Google Places (opcional — solo necesaria para autocompletado de direcciones)
VITE_GOOGLE_PLACES_API_KEY=
